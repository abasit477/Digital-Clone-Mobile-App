# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Digital Clone API"
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite for development:
DATABASE_URL=sqlite:///./digital_clone.db
# PostgreSQL for production:
# DATABASE_URL=postgresql://user:password@localhost:5432/digital_clone

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Cognito (must match mobile app config)
COGNITO_USER_POOL_ID=us-east-1_orFUeN52q
COGNITO_CLIENT_ID=78gtfs160lm6m8lvcdovj64krt

# Bedrock model
BEDROCK_MODEL_ID=anthropic.claude-3-7-sonnet-20250219-v1:0

# Polly default voice (used when a clone has no voice_id set)
POLLY_DEFAULT_VOICE=Matthew
POLLY_ENGINE=neural

# ── Provider selection — swap without changing code ──────────────────────────
STT_PROVIDER=whisper    # whisper (local, fast) | aws (batch, slow)
TTS_PROVIDER=aws        # aws | google | elevenlabs (future)
LLM_PROVIDER=aws        # aws | openai (future)
KNOWLEDGE_PROVIDER=chroma  # chroma | pinecone (future)

# faster-whisper model size (only used when STT_PROVIDER=whisper)
WHISPER_MODEL_SIZE=base  # tiny | base | small | medium | large-v3

# ── SadTalker — talking-head video generation ────────────────────────────────
# Absolute path to the cloned SadTalker repo.
# Leave empty to disable; voice messages will return text only.
#
# Setup:
#   git clone https://github.com/OpenTalker/SadTalker.git backend/sadtalker
#   pip install -r backend/sadtalker/requirements.txt
#   bash backend/sadtalker/scripts/download_models.sh
#
SADTALKER_DIR=/absolute/path/to/backend/sadtalker

# ── Static file serving ───────────────────────────────────────────────────────
# External URL of this server — used to build avatar/video URLs sent to mobile.
# Must match EXPO_PUBLIC_API_URL (mobile) minus /api/v1
SERVER_BASE_URL=http://192.168.x.x:8000

# ── SES — for sending family invite emails ────────────────────────────────────
# Must be a verified sender address in AWS SES
SES_SENDER_EMAIL=noreply@yourdomain.com

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
